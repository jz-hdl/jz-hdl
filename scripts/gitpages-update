#!/usr/bin/env bash
set -euo pipefail

# Build the VitePress docs site and deploy to the gh-pages branch.
# Uses a temporary clone so the working repo is never modified.
# Usage: scripts/gitpages-update

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DOCS_DIR="$REPO_ROOT/docs"
DIST_DIR="$DOCS_DIR/.vitepress/dist"

echo "==> Installing dependencies..."
(cd "$DOCS_DIR" && npm install)

echo "==> Building site..."
(cd "$DOCS_DIR" && npm run build)

if [ ! -d "$DIST_DIR" ]; then
  echo "Error: Build output not found at $DIST_DIR"
  exit 1
fi

echo "==> Deploying to gh-pages..."

# Get the remote URL
REMOTE_URL="$(git -C "$REPO_ROOT" remote get-url origin)"

# Work in a temporary clone to avoid touching the working repo
TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

# Clone just the gh-pages branch (shallow), or init a new repo if it doesn't exist
if git ls-remote --heads "$REMOTE_URL" gh-pages | grep -q gh-pages; then
  git clone --depth 1 --branch gh-pages "$REMOTE_URL" "$TMPDIR/deploy"
else
  mkdir "$TMPDIR/deploy"
  git -C "$TMPDIR/deploy" init
  git -C "$TMPDIR/deploy" checkout --orphan gh-pages
  git -C "$TMPDIR/deploy" remote add origin "$REMOTE_URL"
fi

# Remove old site contents (but keep .git)
find "$TMPDIR/deploy" -maxdepth 1 ! -name '.git' ! -path "$TMPDIR/deploy" -exec rm -rf {} +

# Copy built site
cp -r "$DIST_DIR"/. "$TMPDIR/deploy"

# Add .nojekyll to bypass Jekyll processing on GitHub Pages
touch "$TMPDIR/deploy/.nojekyll"

# Commit and push
git -C "$TMPDIR/deploy" add -A
if git -C "$TMPDIR/deploy" diff --cached --quiet; then
  echo "No changes to deploy."
else
  git -C "$TMPDIR/deploy" commit -m "Deploy docs to GitHub Pages"
  git -C "$TMPDIR/deploy" push origin gh-pages
  echo "==> Deployed successfully."
fi

echo "==> Done."
